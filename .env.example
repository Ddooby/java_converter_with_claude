ANTHROPIC_API_KEY=your_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# 변환 입출력 경로 (상대경로는 프로젝트 루트 기준)
INPUT_DIR=converter/dao/input
OUTPUT_DIR=converter/dao/output
PATTERNS_FILE=converter/dao/patterns/learned_patterns.json

# 외부 출력 경로 (비워두면 외부 저장 스킵)
# 변환된 package의 'dao' 세그먼트 이후 sub-path가 각 base에 append됨
# 예: package com.pan.som.dao.standardInfo → standardInfo/ 가 append
EXTERNAL_DAO_BASE=C:\Projects\Panocean\src\main\java\com\pan\som\dao
EXTERNAL_MAPPER_BASE=C:\Projects\Panocean\src\main\resources\mappers\som

# 기존 파일 존재 시 동작 모드
# overwrite : 무조건 덮어쓰기 (기본값)
# skip      : 존재하면 건너뜀
# backup    : {파일명}.bak.{YYYYMMDD_HHMMSS} 로 백업 후 덮어쓰기
OVERWRITE_MODE=overwrite
